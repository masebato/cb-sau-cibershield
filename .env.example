PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=*

# M2M — secreto compartido con el API Gateway (cibershield)
M2M_SECRET=changeme_m2m_secret

# JWT — tokens de usuario firmados por este servicio
JWT_SECRET=changeme_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Base de datos
DB_HOST=localhost
DB_PORT=5433
DB_NAME=cibershield_sau
DB_USER=postgres
DB_PASSWORD=changeme
